<view class="picker-overlay {{visible ? 'show' : ''}}">
  <view class="picker-backdrop" bindtap="onClose"></view>
  <view class="picker-sheet">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择下注积分</view>
    <view class="quick-row">
      <view
        wx:for="{{quickAmounts}}"
        wx:key="*this"
        class="quick-btn"
        data-amount="{{item}}"
        bindtap="onQuickBet"
      >{{item}}</view>
    </view>
    <view class="quick-row">
      <view class="quick-btn all-in" bindtap="onAllIn">ALL IN</view>
    </view>
    <view class="custom-row">
      <input
        class="custom-input"
        type="number"
        adjust-position="{{false}}"
        placeholder="自定义积分"
        placeholder-style="color:#636e72"
        value="{{customAmount}}"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        bindinput="onCustomInput"
      />
      <view class="custom-confirm" bindtap="onCustomConfirm">确认</view>
    </view>
    <view class="score-hint">剩余积分：{{score}}</view>
  </view>
</view>
