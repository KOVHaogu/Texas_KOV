page {
  background-color: #2c1810;
  color: #dfe6e9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 14px;
  --bg-primary: #2c1810;
  --bg-panel: #1a0e08;
  --border-color: #3d2015;
  --text-primary: #dfe6e9;
  --text-secondary: #636e72;
  --accent: #e17055;
  --accent-light: #fab1a0;
  --gold: #ffeaa7;
  --bet-green: #00b894;
  --win-blue: #0984e3;
  --danger-red: #d63031;
}

button {
  font-size: 16px;
}

button::after {
  border: none;
}
