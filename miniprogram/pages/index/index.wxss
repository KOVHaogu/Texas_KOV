.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48px 24px 32px;
  box-sizing: border-box;
}

.brand {
  text-align: center;
  margin-bottom: 48px;
}
.brand-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 8px;
}
.brand-title {
  font-size: 26px;
  font-weight: 700;
  color: #ffeaa7;
  display: block;
  letter-spacing: 2px;
}
.brand-mark {
  font-size: 10px;
  color: #e17055;
  letter-spacing: 4px;
  text-align: center;
  display: block;
  margin-top: 32px;
  opacity: 0.5;
}

.profile-setup {
  display: flex;
  align-items: center;
  gap: 14px;
  background: #1a0e08;
  border-radius: 16px;
  padding: 14px 18px;
  margin-bottom: 32px;
  width: 100%;
  max-width: 300px;
  box-sizing: border-box;
  border: 1px solid rgba(225, 112, 85, 0.15);
}
.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  flex-shrink: 0;
}
.avatar-btn::after { border: none; }
.profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 2px solid rgba(225, 112, 85, 0.5);
  background: #3d2015;
}
.profile-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e17055;
  color: #fff;
  font-size: 24px;
}
.nickname-input {
  flex: 1;
  color: #dfe6e9;
  font-size: 16px;
  background: transparent;
  border: none;
  padding: 8px 0;
}

.actions {
  width: 100%;
  max-width: 300px;
}
.btn {
  width: 100%;
  border-radius: 16px;
  font-weight: 700;
  text-align: center;
}
.btn-create {
  background: #e17055;
  color: #fff;
  padding: 18px 0;
}
.btn-text {
  display: block;
  font-size: 18px;
}
.btn-hint {
  display: block;
  font-size: 11px;
  margin-top: 3px;
  opacity: 0.7;
}
.divider {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 22px 0;
}
.divider-line {
  flex: 1;
  height: 1px;
  background: #3d2015;
}
.divider-text {
  color: #636e72;
  font-size: 12px;
  white-space: nowrap;
}
.join-box {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.join-input {
  background: #1a0e08;
  border: 1px solid #3d2015;
  color: #dfe6e9;
  padding: 16px;
  border-radius: 14px;
  font-size: 20px;
  text-align: center;
  letter-spacing: 10px;
}
.btn-join {
  background: #0984e3;
  color: #fff;
  padding: 16px 0;
  font-size: 18px;
  border-radius: 14px;
}
.btn-join.disabled {
  background: #3d2015;
  color: #636e72;
}
